# Database configuration
DATABASE_URL=postgresql://geoscan:geoscan@localhost:5432/geoscan
DATABASE_ENABLED=true

# Groq API Configuration
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx
